    "@type": "Organization",
    "name": "Open Research Repository (Teaching)"
  },
  "identifier": "10.1234/gcd-2025",
  "keywords": [
    "climate",
    "temperature",
    "rainfall",
    "CO2 emissions",
    "teaching dataset"
  ],
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "distribution": [
    {
      "@type": "DataDownload",
      "encodingFormat": "text/csv",
      "contentUrl": "data/raw/climate_sample.csv",
      "name": "climate_sample.csv"
    }
  ]
}

